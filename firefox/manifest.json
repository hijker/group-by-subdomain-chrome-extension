{
  "manifest_version": 2,
  "name": "Tab Grouper by Subdomain",
  "version": "1.0.0",
  "description": "Automatically groups tabs by domain and subdomain into Firefox's native tab groups.",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Tab Grouper by Subdomain"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{e5a52d0a-1234-5678-90ab-cdef12345678}",
      "strict_min_version": "131.0"
    }
  }
}
